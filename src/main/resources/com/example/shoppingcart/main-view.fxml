<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.shoppingcart.MainController"
      spacing="12"
      alignment="TOP_LEFT">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <Label fx:id="languageLabel"/>
        <ComboBox fx:id="languageComboBox" prefWidth="180"/>
    </HBox>

    <HBox spacing="10">
        <Label fx:id="itemNameLabel"/>
        <TextField fx:id="itemNameField"/>

        <Label fx:id="priceLabel"/>
        <TextField fx:id="priceField"/>

        <Label fx:id="quantityLabel"/>
        <TextField fx:id="quantityField"/>
    </HBox>

    <HBox spacing="10">
        <Button fx:id="addItemButton" onAction="#handleAddItem"/>
        <Button fx:id="calculateButton" onAction="#handleCalculate"/>
        <Button fx:id="clearButton" onAction="#handleClear"/>
        <Button fx:id="saveButton" onAction="#handleSave"/>
    </HBox>

    <TableView fx:id="cartTable" prefHeight="260">
        <columns>
            <TableColumn fx:id="nameColumn" prefWidth="180"/>
            <TableColumn fx:id="priceColumn" prefWidth="120"/>
            <TableColumn fx:id="quantityColumn" prefWidth="120"/>
            <TableColumn fx:id="totalColumn" prefWidth="180"/>
        </columns>
    </TableView>

    <Label fx:id="overallTotalLabel"/>
    <Label fx:id="resultLabel" text="0.00" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
</VBox>